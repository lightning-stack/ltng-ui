<main class="split-screen-layout" data-theme="dark">
  <section class="brand-panel">
    <h1>
Welcome to AuthAPI
    </h1>
    <p class="subtitle">
Secure identity infrastructure.
    </p>
  </section>
  <section class="form-panel">
    <form id="login-form" method="POST" onSubmit="function handleLogin() {}">
      <div class="form-group">
        <label for="email">
Email Address
        </label>
        <input id="email" required="true" type="email" />
      </div>
      <button class="btn btn--lg btn--primary" type="submit">
Sign In
      </button>
    </form>
  </section>
</main>